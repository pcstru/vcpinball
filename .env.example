# Pinball eval-agent provider environment template
# What: sample env variables used by tools/eval-agent.js.
# Why: make local setup explicit without storing real secrets in git.

# Primary provider (required for provider-loop)
PIN_AI_BASE_URL=https://api.openai.com/v1
PIN_AI_API_KEY=replace-with-real-key
PIN_AI_MODEL=gpt-4.1

# Optional review/scoring provider (leave blank to disable review)
PIN_AI_REVIEW_BASE_URL=
PIN_AI_REVIEW_API_KEY=
PIN_AI_REVIEW_MODEL=
