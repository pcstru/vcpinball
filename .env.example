# Pinball provider environment template
# What: sample env variables used by eval-agent and the local GEPA launcher.
# Why: make local setup explicit without storing real secrets in git.
#
# If you are tempted to paste a real key into a script instead, resist that
# heroic impulse. `.env` is already ignored; the script is not your vault.

# Primary provider (required for provider-loop)
PIN_AI_BASE_URL=https://api.openai.com/v1
PIN_AI_API_KEY=replace-with-real-key
PIN_AI_MODEL=gpt-4.1

# Optional reflection provider for GEPA. Leave blank to reuse PIN_AI_*.
PIN_REFLECTION_BASE_URL=
PIN_REFLECTION_API_KEY=
PIN_REFLECTION_MODEL=

# Optional review/scoring provider (leave blank to disable review)
PIN_AI_REVIEW_BASE_URL=
PIN_AI_REVIEW_API_KEY=
PIN_AI_REVIEW_MODEL=
